# Postgres — shared by the orchestrator's LangGraph checkpointer and the target app's repository layer.
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=orchestrator
POSTGRES_DB=orchestrator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Orchestrator Coder-node mode: "replay" (default, no login needed) or "live" (requires an
# authenticated `claude` CLI on the host, bind-mounted via docker-compose.override.yml).
ORCHESTRATOR_MODE=replay

# Base URL the orchestrator uses to reach the target app over the Compose network.
TARGET_APP_URL=http://target_app:8000
